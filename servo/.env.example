# ── Frontend (apps/web) ─────────────────────────────────────────────────────
# Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key

# Render API base URL (used by the SPA to call the Fastify backend)
VITE_API_BASE_URL=http://localhost:3001

# ── Backend (apps/api) ──────────────────────────────────────────────────────
# Supabase project URL (same value as above)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key — NEVER expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key for the AI assistant endpoint
ANTHROPIC_API_KEY=sk-ant-...

# Allowed CORS origin for the API (set to your Vercel deployment URL in prod)
CORS_ORIGIN=http://localhost:5173

# Port the Fastify server listens on (Render sets this automatically)
PORT=3001

# ── Payments (deferred — Phase 8) ───────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
